  "residualRisks": [
    {
      "id": "RR-CONVENIENCE-SAME-USER",
      "title": "Convenience does not isolate secrets from the same OS user",
      "statement": "Convenience protects stored bytes with the platform store but does not make the current user account a process-level security boundary. Same-user enumeration, runtime invocation and process-memory inspection are expected residuals, not successful denial tests.",
      "owner": "patryk-roguszewski",
      "reviewDate": "2026-10-15",
      "adrRefs": [
        "ADR-0004"
      ]
    },
    {
      "id": "RR-PRIVILEGED-HOST-COMPROMISE",
      "title": "A compromised privileged host remains outside the Hardened boundary",
      "statement": "Hardened tiers fail closed for supported local attacks but do not claim protection after compromise of the operating-system kernel, trusted signing identity or platform root of trust.",
      "owner": "patryk-roguszewski",
      "reviewDate": "2026-10-15",
      "adrRefs": [
        "ADR-0004"
      ]
    },
    {
      "id": "RR-LINUX-AGENT-UID",
      "title": "Linux Hardened trusts the dedicated Agent UID as one workload principal",
      "statement": "Linux Hardened isolates broker-held identity, the master key, broker memory and broker state from the Agent UID, but it does not isolate sibling processes inside that dedicated workload UID. Agent authority, transient input and client memory are shared residuals, so operators must not run unrelated applications under it.",
      "owner": "patryk-roguszewski",
      "reviewDate": "2026-10-15",
      "adrRefs": [
        "ADR-0004"
      ]
    },
    {
      "id": "RR-MUSL-NO-HARDENED",
      "title": "Linux musl has no Hardened tier",
      "statement": "Linux musl and Alpine are Convenience-only for the MVP. A musl target must never report Hardened and the absent tier is recorded explicitly as not applicable.",
      "owner": "patryk-roguszewski",
      "reviewDate": "2026-10-15",
      "adrRefs": [
        "ADR-0004"
      ]
    },
    {
      "id": "RR-AUTHORIZED-DESTINATION",
      "title": "An authorized destination can retain a credential it legitimately receives",
      "statement": "Palladin can constrain which runtime performs an operation, but it cannot revoke plaintext already delivered to an explicitly authorized destination. Tests therefore attack authorization and transport boundaries rather than claiming control over the destination after delivery.",
      "owner": "patryk-roguszewski",
      "reviewDate": "2026-10-15",
      "adrRefs": [
        "ADR-0004"
      ]
    }
  ],
