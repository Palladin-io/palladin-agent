  "totpUriAcceptances": [
    {
      "name": "uppercase-recognized-names-and-trimmed-secret",
      "uri": "otpauth://totp/Palladin:alice?SECRET=%20JBSWY3DP%20&ALGORITHM=sha256&DIGITS=8&PERIOD=60",
      "expectedSecret": "JBSWY3DP",
      "expectedAlgorithm": "SHA256",
      "expectedDigits": 8,
      "expectedPeriod": 60
    },
    {
      "name": "percent-encoded-recognized-names",
      "uri": "otpauth://totp/Palladin:alice?se%63ret=JBSWY3DP&algor%69thm=SHA1&dig%69ts=6&per%69od=30",
      "expectedSecret": "JBSWY3DP",
      "expectedAlgorithm": "SHA1",
      "expectedDigits": 6,
      "expectedPeriod": 30
    },
    {
      "name": "duplicate-unknown-parameters-remain-forward-compatible",
      "uri": "otpauth://totp/Palladin:alice?secret=JBSWY3DP&account=alice&issuer=one&issuer=two&future=&future=value",
      "expectedSecret": "JBSWY3DP",
      "expectedAlgorithm": "SHA1",
      "expectedDigits": 6,
      "expectedPeriod": 30
    }
  ],
