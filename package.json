{
  "name": "@palladin/agent",
  "version": "0.1.0",
  "description": "Palladin Agent CLI and MCP server",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Palladin-io/palladin-agent.git"
  },
  "homepage": "https://palladin.io",
  "bugs": {
    "url": "https://github.com/Palladin-io/palladin-agent/issues"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "palladin": "./dist/bin/palladin.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/palladin.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/curves": "^2.2.0",
    "commander": "^13.1.0",
    "libsodium-wrappers": "^0.8.4",
    "linkedom": "^0.18.12",
    "tldts": "^6.1.86"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "playwright-core": "^1.61.1"
  }
}
