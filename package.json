{
  "name": "@claw-vault/agent",
  "version": "0.1.0",
  "description": "Claw Vault Agents — CLI + MCP server",
  "type": "module",
  "bin": {
    "claw-vault": "./dist/bin/claw-vault.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/claw-vault.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "tsc",
    "postprepare": "node dist/bin/claw-vault.js init"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/curves": "^2.2.0",
    "commander": "^13.1.0",
    "libsodium-wrappers": "^0.8.4"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.3.0"
  }
}
